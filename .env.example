# Copy to .env (not committed) and set your key. Never commit .env.
# OpenRouter: get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key-here
# Corporate proxy / SSL inspect: set to 0 if certificate verify fails locally
OPENROUTER_SSL_VERIFY=1
# Free tier vision (recommended for Maestro screenshot verify):
#   meta-llama/llama-3.2-11b-vision-instruct:free  — reliable JSON + image input on OpenRouter free tier
# Paid (best accuracy):
#   openai/gpt-4.1-mini   — faster, strong vision (paid)
OPENROUTER_MODEL_VISION=meta-llama/llama-3.2-11b-vision-instruct:free
# Comma-separated vision fallbacks when primary model fails (404/429/5xx). Set to none to disable.
# OPENROUTER_VISION_FALLBACKS=qwen/qwen2.5-vl-32b-instruct:free,qwen/qwen2.5-vl-72b-instruct:free,google/gemma-3-4b-it:free,mistralai/mistral-small-3.1-24b-instruct:free
# Post-Maestro visual validation module (ai/visual_validation.py)
AI_VISUAL_MODEL=meta-llama/llama-3.2-11b-vision-instruct:free
