# Copy to .env (not committed) and set your key. Never commit .env.
# OpenRouter: get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key-here
# Corporate proxy / SSL inspect: set to 0 if certificate verify fails locally
OPENROUTER_SSL_VERIFY=1
# Vision model for ED_02/ED_03/GA_02 AI verify scripts (OpenRouter multimodal).
# Recommended when you have OpenRouter credits:
#   openai/gpt-4.1        — best accuracy for pinch/crop framing diffs (paid)
#   openai/gpt-4.1-mini   — cheaper, still strong vision (paid)
# Free tier (no credits required):
#   meta-llama/llama-3.2-11b-vision-instruct:free  — recommended for editing AI verify
#   openrouter/free       — generic free router (less reliable JSON for vision)
OPENROUTER_MODEL_VISION=meta-llama/llama-3.2-11b-vision-instruct:free
